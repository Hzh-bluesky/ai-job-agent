# MySQL
DB_URL=jdbc:mysql://localhost:3306/ai_job_agent?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=ai_job_agent_user
DB_PASSWORD=change-me

# JWT
JWT_SECRET=please-change-this-jwt-secret-at-least-32-bytes
JWT_EXPIRATION_SECONDS=86400

# LLM provider: mock, fastapi, deepseek, groq, qwen
LLM_PROVIDER=mock
DEEPSEEK_API_KEY=
GROQ_API_KEY=
DASHSCOPE_API_KEY=

# Python AI service
AI_SERVICE_BASE_URL=http://localhost:8000
AI_SERVICE_PROVIDER=qwen
AI_SERVICE_MODEL=qwen-plus
AI_SERVICE_TIMEOUT_SECONDS=90
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
